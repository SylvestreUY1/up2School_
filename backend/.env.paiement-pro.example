# PaiementPro Configuration
# Replace CINETPAY_* environment variables with PAIEMENT_PRO_*

# Merchant ID from PaiementPro
# Get this from your PaiementPro dashboard at https://paiementpro.net
PAIEMENT_PRO_MERCHANT_ID=your_merchant_id_here

# Example: PAIEMENT_PRO_MERCHANT_ID=PP-F324

# Subscription amount in XOF (must be multiple of 5)
# This is already configured via UP2SCHOOL_SUBSCRIPTION_AMOUNT
UP2SCHOOL_SUBSCRIPTION_AMOUNT=350

# The REST of your backend configuration remains the same
# See functions/.env.example for other variables
