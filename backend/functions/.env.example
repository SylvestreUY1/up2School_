NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=https://up2school-api.onrender.com

# Firebase Admin / Firebase Auth REST
FIREBASE_PROJECT_ID=up2school-app
FIREBASE_API_KEY=your_firebase_web_api_key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"up2school-app","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-xxx@up2school-app.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxx%40up2school-app.iam.gserviceaccount.com"}

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_PROJECT_ID=your_project_ref

# Cloudflare R2
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=up2school-files
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_S3_API_URL=https://your-account-id.r2.cloudflarestorage.com/up2school-files

# Payments
CINETPAY_API_KEY=your_cinetpay_api_key
CINETPAY_SITE_ID=your_cinetpay_site_id
CINETPAY_SECRET_KEY=your_cinetpay_secret_key
UP2SCHOOL_SUBSCRIPTION_AMOUNT=1000

# Security
FILE_ACCESS_TOKEN_SECRET=replace_with_a_long_random_secret
JWT_SECRET=replace_with_another_long_random_secret
